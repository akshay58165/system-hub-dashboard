{
  "name": "unicorns-desk",
  "productName": "Unicorn's Desk",
  "private": true,
  "version": "7.7.0",
  "description": "Unicorn's Desk — creator command center for LearnDriven & DecodeWorthy.",
  "author": {
    "name": "Akshay",
    "email": "typeakshay@gmail.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js dist-electron",
    "lint": "tsc --noEmit",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "electron:build": "vite build && electron-builder --win --publish never",
    "electron:build:portable": "vite build && electron-builder --win portable --publish never"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.109.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.akshay.unicornsdesk",
    "productName": "Unicorn's Desk",
    "copyright": "Copyright © 2026 Akshay",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "UnicornsDesk-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Unicorn's Desk"
    },
    "portable": {
      "artifactName": "UnicornsDesk-${version}-portable.exe"
    }
  }
}
