# Browser-safe public configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# OAuth client ID for the real YouTube Analytics revenue integration
# (Command Center's Revenue tile). Public/browser-safe by design.
VITE_YOUTUBE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
# Server-only configuration for the authenticated /api/openai function.
# Never add a VITE_ prefix to these values.
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# Optional: enables real account-wide spend in the Script Editor's usage
# panel via OpenAI's Costs API. This is an Admin API key (organization owner
# only), generated at platform.openai.com/settings/organization/admin-keys
# with the api.usage.read scope — a different key type from OPENAI_API_KEY
# above. Without it, the panel falls back to its own in-app token tracker.
OPENAI_ADMIN_API_KEY="your-openai-admin-api-key"
# Required for the real YouTube Analytics revenue integration. The client
# secret paired with VITE_YOUTUBE_CLIENT_ID above — from the SAME OAuth
# client in Google Cloud Console (APIs & Services > Credentials). Never
# expose this with a VITE_ prefix; it's used only in api/youtube-auth-callback.js
# and api/youtube-revenue.js to exchange/refresh tokens server-side.
YOUTUBE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="your-google-oauth-client-secret"
# The exact production origin used to build the OAuth redirect URI
# (must match an Authorized redirect URI registered on the OAuth client:
# <APP_URL>/api/youtube-auth-callback). Defaults to the production domain
# if unset.
APP_URL="https://system-hub-dashboard.vercel.app"
